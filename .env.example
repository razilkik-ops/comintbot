# Токен из BotFather
BOT_TOKEN=1234567890:PASTE_YOUR_TOKEN_HERE

# Порт Node.js приложения на сервере
PORT=3000

# Публичный HTTPS-адрес, на котором доступен этот Node.js бот.
# Можно отдельный поддомен: https://bot.comint.by
# Или путь на основном домене, если проксируете Node через Nginx: https://comint.by
PUBLIC_BASE_URL=https://bot.comint.by

# Секретный путь webhook. Придумайте длинную случайную строку без пробелов.
WEBHOOK_PATH_SECRET=replace-with-long-random-url-secret

# Секретный Telegram header для проверки webhook. Только A-Z, a-z, 0-9, _ и -.
TELEGRAM_SECRET_TOKEN=replace-with-secret-token

# ID Telegram-группы менеджеров. Получите через команду /chatid в группе.
# Обычно выглядит так: -1001234567890
MANAGER_CHAT_ID=

COMPANY_NAME=Коминт

# Имя бота в приветствии и имя менеджера в сценарии сложных заявок
BOT_ASSISTANT_NAME=Арина
SALES_MANAGER_NAME=Екатерина

# Скидка, которую бот обещает в воронке сувенирной продукции
FIRST_ORDER_DISCOUNT=5
